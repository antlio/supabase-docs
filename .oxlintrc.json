{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "plugins": ["typescript", "react", "nextjs", "oxc", "unicorn"],
  "categories": {
    "correctness": "error",
    "suspicious": "warn"
  },
  "rules": {
    "react/react-in-jsx-scope": "off",
    "no-restricted-imports": [
      "error",
      {
        "paths": [
          {
            "name": "react",
            "importNames": ["useEffect"],
            "message": "useEffect is banned — see NO_USE_EFFECT.md. Derive state, use TanStack Query, event handlers, or useMountEffect."
          }
        ]
      }
    ]
  },
  "overrides": [
    {
      "files": ["src/hooks/use-mount-effect.ts"],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
  "ignorePatterns": [".next", "node_modules", "research", "assets"]
}
